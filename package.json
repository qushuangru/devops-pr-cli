{
  "name": "devops-pr-cli",
  "version": "1.0.1",
  "description": "CLI tool for creating and managing Azure DevOps pull requests",
  "main": "dist/index.js",
  "bin": {
    "devops-pr": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "azure-devops",
    "pull-request",
    "cli",
    "git",
    "pr",
    "azdo",
    "devops"
  ],
  "author": "Shuangru Qu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qushuangru/devops-pr-cli.git"
  },
  "bugs": {
    "url": "https://github.com/qushuangru/devops-pr-cli/issues"
  },
  "homepage": "https://github.com/qushuangru/devops-pr-cli#readme",
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "axios": "^1.6.2",
    "simple-git": "^3.21.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.3",
    "date-fns": "^3.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "README_CN.md",
    "LICENSE"
